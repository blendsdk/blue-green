# =============================================================================
# {{PROJECT_NAME}} — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git — it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Project
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME={{PROJECT_NAME_LOWER}}

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Number of app container replicas per color (blue or green)
APP_REPLICAS={{APP_REPLICAS}}

# Which environment is currently receiving traffic: "blue" or "green"
# This is updated automatically by scripts/remote-ops.sh switch-color
ACTIVE_ENV=blue

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
# Port exposed on the host (ProxyBuilder forwards traffic here)
NGINX_HTTP_PORT={{NGINX_PORT}}

# -----------------------------------------------------------------------------
# Health Check Configuration
# -----------------------------------------------------------------------------
# Used by scripts/remote-ops.sh and scripts/health-check-wait.sh
HEALTH_CHECK_RETRIES=5
HEALTH_CHECK_INTERVAL=2

# -----------------------------------------------------------------------------
# Dozzle — Web-based log viewer
# -----------------------------------------------------------------------------
DOZZLE_PORT=9999
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=changeme_dozzle_password

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Europe/Amsterdam

{{ENV_POSTGRES_PARTIAL}}{{ENV_REDIS_PARTIAL}}{{ENV_BACKUP_PARTIAL}}
